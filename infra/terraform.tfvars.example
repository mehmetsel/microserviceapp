aws_region           = "us-east-1"
project_name         = "microservice"
environment          = "prod"
auth_user            = "admin"
auth_pass            = "change-me-before-deploy"
instance_type        = "t3.micro"
asg_min_size         = 2
asg_max_size         = 4
asg_desired_capacity = 2
image_tag            = "latest"
cache_ttl_seconds    = 60
